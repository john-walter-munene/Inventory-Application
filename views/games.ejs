<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Games</title>
    <link rel="icon" href="/icons/games.webp">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/games.css">
    <script src="/js/header.js" defer></script>
</head>

<body>

    <%- include('partials/header') %>

    <main>

        <!-- FILTER / TOP BAR -->
        <section class="filters">

            <div class="page-header">
                <h2>Browse Games</h2>

                <a href="/games/new" class="btn">
                    Add Game
                </a>
            </div>

            <form method="GET" action="/games" class="filter-bar">

                <!-- SORT -->
                <div class="filter-group inline">
                    <h3>Sort</h3>

                    <label>
                        <input type="radio" name="order" value="title-ascending"
                            <%= selectedOrder === 'title-ascending' ? 'checked' : '' %>
                        > A→Z
                    </label>

                    <label>
                        <input type="radio" name="order" value="title-descending"
                            <%= selectedOrder === 'title-descending' ? 'checked' : '' %>
                        > Z→A
                    </label>

                    <label>
                        <input type="radio" name="order" value="price-ascending"
                            <%= selectedOrder === 'price-ascending' ? 'checked' : '' %>
                        > Price↑
                    </label>

                    <label>
                        <input type="radio" name="order" value="price-descending"
                            <%= selectedOrder === 'price-descending' ? 'checked' : '' %>
                        > Price↓
                    </label>
                </div>

                <!-- GENRES -->
                <div class="filter-group inline genres">
                    <h3>Genres</h3>

                    <% for (let i = 0; i < genres.length; i++) { %>
                        <% const g = genres[i]; %>

                        <label>
                            <input type="checkbox"
                                name="genres"
                                value="<%= g.id %>"
                                <%= selectedGenres.includes(g.id) ? 'checked' : '' %>
                            >
                            <span style="color:<%= g.color %>"><%= g.name %></span>
                        </label>

                    <% } %>
                </div>

                <button type="submit" class="apply-btn">
                    Apply
                </button>

            </form>

        </section>

        <!-- RESULTS -->
        <section class="games-list">

            <% if (games.length > 0) { %>

                <div class="games-grid">

                    <% for (let i = 0; i < games.length; i++) { %>
                        <% const game = games[i]; %>

                        <a href="/games/<%= game.id %>" class="game-card">

                            <img src="<%= game.image_url %>" alt="<%= game.title %>">

                            <div class="game-info">
                                <h3><%= game.title %></h3>
                                <p><%= game.description %></p>
                                <p class="price">$ <%= game.price %></p>
                            </div>

                        </a>

                    <% } %>

                </div>

            <% } else { %>

                <p>No games found.</p>

            <% } %>

        </section>

    </main>

    <%- include('partials/footer') %>

</body>
</html>