<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <link rel="icon" href="/icons/games.webp">
    <title>Gamies Search</title>
    <script src="/js/header.js" defer></script>
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/search.css">
</head>
<body>

    <header>
        <%- include('partials/header') %>
    </header>

    <main>
        <section class="search-hero">
            <h2>Search results for "<%= search %>"</h2>

            <p>
                <% if (results.length > 0) { %>
                    Found <%= results.length %> matching game(s).
                <% } else { %>
                    No games matched your search.
                <% } %>
            </p>

            <a href="/games" class="back-link">← Return to Products</a>
        </section>

        <!-- Results -->
        <section class="search-results">

            <% if (results.length > 0) { %>

                <div class="results-grid">
                    <% for (let i = 0; i < results.length; i++) { %>
                        <% const game = results[i]; %>
                        <article class="game-card">
                            <div class="game-image">
                                <img src="<%= game.image_url %>" alt="<%= game.title %>">
                            </div>

                            <div class="game-details">
                                <h3><%= game.title %></h3>
                                <p class="genre">Genre: <%= game.genre_name || 'Unknown' %></p>
                                <p class="description"><%= game.description %></p>

                                <div class="meta">
                                    <span>$ <%= game.price %></span>
                                    <span>Stock: <%= game.quantity %></span>
                                </div>

                                <a href="/games/<%= game.id %>" class="view-btn">View Game</a>
                            </div>
                        </article>
                    <% } %>
                </div>

            <% } else { %>

                <div class="empty-state">
                    <h3>No results found</h3>
                    <p>
                        Try another keyword or browse all available games.
                    </p>

                    <a href="/games" class="view-btn">Browse Games</a>
                </div>
            <% } %>
        </section>
    </main>
    <%- include('partials/footer') %>
</body>
</html>