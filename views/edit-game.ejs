<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" href="/icons/games.webp">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/add-game.css">
    <script src="/js/header.js" defer></script>
</head>

<body>
    <%- include('partials/header') %>

    <main>
        <h2><%= title %></h2>

        <% if (errors && errors.length > 0) { %>
            <div class="error-container">
                <ul class="error-list">
                    <% errors.forEach(error => { %>
                        <li><%= error.msg %></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>

        <form action="<%= action %>" method="POST" enctype="multipart/form-data">
            <!-- Game Title -->
            <div class="form-group">
                <label for="title">Game Name</label>
                <input type="text" id="title" name="title" value="<%= formData.title %>">
            </div>

            <!-- Price -->
            <div class="form-group">
                <label for="price">Price</label>
                <input type="number" id="price" name="price" 
                    step="1" min="1" value="<%= formData.price %>" required>
            </div>

            <!-- Quantity -->
            <div class="form-group">
                <label for="quantity">Quantity</label>
                <input type="number" id="quantity" name="quantity"
                    min="0" value="<%= formData.quantity %>" required>
            </div>

            <!-- Image -->
            <div class="form-group">
                <label for="image">Game Image</label>
                <input type="file" id="image" name="image" accept="image/*">
                <small>Leave empty to keep current image</small>
            </div>

            <!-- Genre -->
            <div class="form-group">
                <label for="genre">Genre</label>
                <select id="genre" name="genre" required>
                    <option value="">Select Genre</option>

                    <% for (const genre of genresList) { %>
                        <option value="<%= genre.id %>"
                            <%= String(formData.genre) === String(genre.id) ? 'selected' : '' %>
                            ><%= genre.name %>
                        </option>
                    <% } %>
                </select>
            </div>

            <!-- DESCRIPTION -->
            <div class="form-group">
                <label for="description">Description</label>

                <textarea id="description" name="description" rows="5"><%= formData.description %></textarea>
            </div>

            <!-- SUBMIT -->
            <button type="submit">
                <%= title.includes('Edit') ? 'Update Game' : 'Add Game' %>
            </button>
        </form>

    </main>

    <%- include('partials/footer') %>

</body>
</html>